{
  "name": "@agenticapps/dashboard-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./daemon": {
      "types": "./src/daemon.ts",
      "import": "./dist/daemon.js",
      "default": "./dist/daemon.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsup src/index.ts src/daemon.ts --format esm --out-dir dist"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
